{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":rebaseStalePrs"
  ],
  "timezone": "America/Los_Angeles",
  "schedule": ["after 7am and before 3pm on monday"],
  "labels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "prConcurrentLimit": 8,
  "prHourlyLimit": 4,
  "prCreation": "not-pending",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["after 3am and before 5am on tuesday"]
  },
  "packageRules": [
    {
      "description": "Automerge safe updates (patch/minor/digest only) — CI must pass",
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    },
    {
      "description": "Never automerge majors",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group non-major JS deps weekly",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major dependencies"
    },
    {
      "description": "Group GitHub Actions patch/minor/digest updates only — never automerge major Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "groupName": "github actions dependencies",
      "automerge": true,
      "platformAutomerge": false
    },
    {
      "description": "Core frontend + backend deps require manual review",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "typescript", "react", "react-dom", "next",
        "fastify", "@supabase/supabase-js", "@supabase/ssr",
        "bullmq", "tailwindcss", "zod"
      ],
      "automerge": false,
      "groupName": "core deps (manual review)"
    }
  ]
}
